# Dynatrace — get from your tenant at dynatrace.com/signup
DT_ENVIRONMENT_ID=abc12345
DT_API_TOKEN=dt0c01.xxxxx
DT_OTLP_ENDPOINT=https://abc12345.live.dynatrace.com/api/v2/otlp

# Google / Gemini — from aistudio.google.com
GEMINI_API_KEY=AIza...
# If using Vertex AI instead of a direct API key:
# GOOGLE_CLOUD_PROJECT=your-project
# GOOGLE_GENAI_USE_VERTEXAI=true

# Depcon behaviour (optional — these are the defaults)
# DEPCON_SKIP=1          # set to bypass the hook entirely (useful in CI)
# DEPCON_TIMEOUT=120     # max seconds for a full run before fail-open
# DEPCON_CONFIDENCE_THRESHOLD=medium   # block at: low | medium | high
